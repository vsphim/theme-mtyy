{
    "name": "vsmov/theme-mtyy",
    "description": "VsMov's mtyy theme",
    "type": "library",
    "authors": [
        {
            "name": "vsmov",
            "email": "dev@vsmov.cc"
        }
    ],
    "require": {
        "laravel/framework": "^6|^7|^8",
        "ckfinder/ckfinder-laravel-package": "v3.5.2.1",
        "vsmov/vsmov-core": "^1.0.0"
    },
    "license": "MIT",
